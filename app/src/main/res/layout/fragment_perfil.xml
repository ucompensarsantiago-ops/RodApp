<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/login_background_color"
    tools:context=".main.perfil.PerfilFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Tarjeta de perfil -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp"
            android:background="@color/login_input_background_color"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Foto de perfil circular con botón de edición -->
            <FrameLayout
                android:id="@+id/frameLayoutProfilePhoto"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="12dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless">

                <ImageView
                    android:id="@+id/imageViewProfilePhoto"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:background="@drawable/bg_profile_photo"
                    android:clipToOutline="true"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_person_placeholder"
                    android:contentDescription="Foto de perfil" />

                <!-- Overlay inferior con texto "Editar" -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="28dp"
                    android:layout_gravity="bottom"
                    android:background="#AA000000"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Editar"
                        android:textColor="#FFFFFF"
                        android:textSize="11sp" />
                </LinearLayout>

            </FrameLayout>

            <TextView
                android:id="@+id/textViewProfileFullName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:textColor="@color/login_text_color"
                android:textSize="22sp"
                android:textStyle="bold"
                tools:text="Juan García" />

            <TextView
                android:id="@+id/textViewProfileRole"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="4dp"
                android:textColor="@color/login_text_color"
                android:textSize="14sp"
                tools:text="Nivel de cuenta: Cliente" />

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp"
            android:text="Editar Perfil"
            android:textColor="@color/login_text_color"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Nombres"
            android:textColor="@color/login_text_color" />

        <EditText
            android:id="@+id/editTextProfileName"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="8dp"
            android:background="@color/login_input_background_color"
            android:hint="Nombres"
            android:inputType="textPersonName"
            android:padding="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Apellidos"
            android:textColor="@color/login_text_color" />

        <EditText
            android:id="@+id/editTextProfileLastName"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="8dp"
            android:background="@color/login_input_background_color"
            android:hint="Apellidos"
            android:inputType="textPersonName"
            android:padding="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Correo Electrónico"
            android:textColor="@color/login_text_color" />

        <EditText
            android:id="@+id/editTextProfileEmail"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="8dp"
            android:background="@color/login_input_background_color"
            android:hint="Correo"
            android:inputType="textEmailAddress"
            android:padding="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Nueva Contraseña (opcional)"
            android:textColor="@color/login_text_color" />

        <EditText
            android:id="@+id/editTextProfilePassword"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="8dp"
            android:background="@color/login_input_background_color"
            android:hint="Contraseña"
            android:inputType="textPassword"
            android:padding="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Confirmar Contraseña"
            android:textColor="@color/login_text_color" />

        <EditText
            android:id="@+id/editTextProfileConfirmPassword"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="8dp"
            android:background="@color/login_input_background_color"
            android:hint="Re-contraseña"
            android:inputType="textPassword"
            android:padding="12dp" />

        <LinearLayout
            android:id="@+id/layoutBiometricToggle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:visibility="gone">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Habilitar huella digital"
                android:textColor="@color/login_text_color"
                android:textSize="16sp" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchBiometric"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:thumbTint="@color/login_button_background_color"
                app:trackTint="@color/login_input_background_color" />
        </LinearLayout>

        <Button
            android:id="@+id/buttonSaveProfile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="32dp"
            android:backgroundTint="@color/login_button_background_color"
            android:text="Guardar Cambios"
            android:textColor="@color/login_button_text_color" />

    </LinearLayout>
</ScrollView>
